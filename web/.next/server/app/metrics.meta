{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/metrics/layout,_N_T_/metrics/page,_N_T_/metrics"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/metrics/__PAGE__",
    "/metrics",
    "/_index",
    "/_head"
  ]
}