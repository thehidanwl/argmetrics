{
  "buildCommand": "cd web && npm install && npm run build",
  "installCommand": "cd web && npm install",
  "outputDirectory": "web/.next",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/api" }
  ],
  "crons": [
    {
      "path": "/api/v1/ingest/usd",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/v1/ingest/inflation",
      "schedule": "0 8 1 * *"
    }
  ]
}
