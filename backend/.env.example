# ─── Database ────────────────────────────────────────────────────────────────
# Supabase (production)
POSTGRES_URL=postgresql://user:password@db.supabase.co:5432/postgres

# SQLite (local development)
# DATABASE_URL=file:./prisma/dev.db

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to authenticate cron/ingest endpoints (Bearer token)
CRON_SECRET=change_this_to_a_random_secret

# ─── External APIs ───────────────────────────────────────────────────────────
BCRA_API_URL=https://api.bcra.gob.ar
BLUELYTICS_API_URL=https://api.bluelytics.com.ar/v2

# ─── Cache TTL (minutes) ─────────────────────────────────────────────────────
CACHE_TTL_USD=30
CACHE_TTL_RISK=60

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
