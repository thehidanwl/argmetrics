// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Metric {
  id          String   @id
  category    String
  name        String
  value       Float
  date        DateTime
  periodType  String   @default("monthly")
  source      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([name])
  @@index([date])
}

model LiveCache {
  key         String   @id
  value       String   // JSON as string
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime
}

model IngestionLog {
  id             String   @id @default(uuid())
  source         String
  metric         String
  status         String
  rowsProcessed  Int      @default(0)
  errorMessage   String?
  executedAt     DateTime @default(now())

  @@index([source])
  @@index([metric])
  @@index([status])
}
