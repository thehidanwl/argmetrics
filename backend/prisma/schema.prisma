generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  economy
  social
  consumption
}

enum PeriodType {
  daily
  monthly
  quarterly
  annually
}

enum IngestionStatus {
  success
  error
  partial
}

model Metric {
  id          String     @id @default(uuid())
  category    Category
  name        String
  value       Decimal    @db.Decimal(20, 6)
  date        DateTime   @db.Date
  periodType  PeriodType @default(monthly)
  source      String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([category])
  @@index([name])
  @@index([date])
  @@map("metrics")
}

model LiveCache {
  key         String   @id
  value       Json
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  expiresAt   DateTime @map("expires_at")

  @@map("live_cache")
}

model IngestionLog {
  id             String          @id @default(uuid())
  source         String
  metric         String
  status         IngestionStatus
  rowsProcessed  Int             @default(0) @map("rows_processed")
  errorMessage   String?         @db.Text @map("error_message")
  executedAt     DateTime        @default(now()) @map("executed_at")

  @@index([source])
  @@index([metric])
  @@index([status])
  @@map("ingestion_log")
}
